{
  "ConnectionStrings": {
    "ClinicalDb": "Server=(localdb)\\MSSQLLocalDB;Database=ClinicalDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Issuer": "Clinical.API",
    "Audience": "Clinical.Clients",
    "SigningKey": "super-secure-signing-key-change-me-in-production-2026",
    "ExpiryMinutes": 60
  },
  "SeedUsers": {
    "Users": [
      {
        "Email": "admin@clinical.local",
        "Password": "Admin123!",
        "FullName": "Clinical Administrator",
        "Role": "Administrator"
      },
      {
        "Email": "doctor@clinical.local",
        "Password": "Doctor123!",
        "FullName": "Dr. Maya Reed",
        "Role": "Doctor"
      },
      {
        "Email": "reception@clinical.local",
        "Password": "Reception123!",
        "FullName": "Reception Desk",
        "Role": "Receptionist"
      }
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/clinical-.log",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
